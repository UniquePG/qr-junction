// Prisma schema for QR Junction
// Streamlined for Phase 1 and optimized for local PostgreSQL

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  OWNER
  ADMIN
  USER
}

enum QRType {
  URL
  TEXT
  WHATSAPP
  EMAIL
  PHONE
  WIFI
  SNAPCHAT
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  TELEGRAM
  TWITTER
  CONTACT
  SMS
  APP_DOWNLOAD
  PDF
  LANDING_PAGE
  REVIEW
  RESTAURANT_MENU
}

enum QRStatus {
  ACTIVE
  PAUSED
  DELETED
}

enum DeviceType {
  MOBILE
  DESKTOP
  TABLET
  UNKNOWN
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum ConversionEventType {
  FORM_SUBMIT
  PURCHASE
  WHATSAPP_CLICK
  CALL_CLICK
  BOOKING
  REGISTRATION
  CUSTOM
}

enum ProfileType {
  INDIVIDUAL
  BUSINESS
}


model User {
  id           Int        @id @default(autoincrement())
  firebaseUid  String     @unique @map("firebase_uid")
  email        String     @unique
  name         String?
  avatarUrl    String?    @map("avatar_url")
  role         UserRole   @default(USER)
  passwordHash String?    @map("password_hash")
  provider     String?
  providerId   String?    @map("provider_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  qrCodes      QRCode[]
  campaigns    Campaign[]
  leads        Lead[]
  landingPages LandingPage[]
  profile      Profile?
  restaurant   Restaurant?

  @@map("users")
}

model Profile {
  id           Int         @id @default(autoincrement())
  userId       Int         @unique @map("user_id")
  type         ProfileType @default(INDIVIDUAL)
  
  // Business / Individual details
  businessName String?     @map("business_name")
  logoUrl      String?     @map("logo_url")
  about        String?     @db.Text
  phone        String?
  website      String?
  address      String?
  industry     String?

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model QRCode {
  id            Int       @id @default(autoincrement())
  shortCode     String    @unique @map("short_code")               // URL identifier: /q/{shortCode}
  name          String
  type          QRType    @default(URL)
  status        QRStatus  @default(ACTIVE)

  // Structured destination data depending on QRType
  destination   Json      // { url?, phone?, message?, email?, ssid?, password?, ... }

  userId        Int       @map("user_id")                          // Links to the creator
  campaignId    Int?      @map("campaign_id")                         // Optional marketing campaign link
  landingPageId Int?      @map("landing_page_id")                     // Optional landing page link
  restaurantId  Int?      @map("restaurant_id")

  // Design appearance
  fgColor       String?   @default("#000000") @map("fg_color")
  bgColor       String?   @default("#FFFFFF") @map("bg_color")
  logoUrl       String?   @map("logo_url")

  // Counters (cached for fast reads)
  totalScans    Int       @default(0) @map("total_scans")
  uniqueScans   Int       @default(0) @map("unique_scans")

  // Custom UTM fields
  utmSource     String?   @map("utm_source")
  utmMedium     String?   @map("utm_medium")
  utmCampaign   String?   @map("utm_campaign")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign      Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  landingPage   LandingPage? @relation(fields: [landingPageId], references: [id], onDelete: SetNull)
  restaurant    Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantTable RestaurantTable?
  scans         Scan[]
  leads         Lead[]
  conversions   Conversion[]
  reviewResponses ReviewResponse[]

  @@index([shortCode])
  @@index([userId])
  @@index([landingPageId])
  @@map("qr_codes")
}

model Scan {
  id             Int        @id @default(autoincrement())
  qrCodeId       Int        @map("qr_code_id")

  // Hash of visitor fingerprint + IP to track unique scans
  visitorId      String     @map("visitor_id")

  // Device Details
  deviceType     DeviceType @default(UNKNOWN) @map("device_type")
  browser        String?
  os             String?
  userAgent      String?    @map("user_agent")

  // Geo Details
  ipAddress      String?    @map("ip_address")
  country        String?
  city           String?
  state          String?
  latitude       Decimal?   @db.Decimal(9, 6)
  longitude      Decimal?   @db.Decimal(9, 6)

  // Referrer & Campaign
  referer        String?
  utmSource      String?    @map("utm_source")
  utmMedium      String?    @map("utm_medium")
  utmCampaign    String?    @map("utm_campaign")

  scannedAt      DateTime   @default(now()) @map("scanned_at")

  qrCode         QRCode     @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  @@index([qrCodeId])
  @@index([scannedAt])
  @@index([visitorId])
  @@map("scans")
}

model ReviewResponse {
  id         Int      @id @default(autoincrement())
  qrCodeId   Int      @map("qr_code_id")
  
  rating     Int      // 1 to 5
  feedback   String?  @db.Text
  
  // Optional lead capture details
  name       String?
  phone      String?
  
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  qrCode     QRCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  @@index([qrCodeId])
  @@map("review_responses")
}

model Campaign {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  userId      Int       @map("user_id")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCodes     QRCode[]
  leads       Lead[]
  conversions Conversion[]

  @@index([userId])
  @@map("campaigns")
}

model Lead {
  id            Int        @id @default(autoincrement())
  name          String
  email         String
  phone         String?
  status        LeadStatus @default(NEW)
  notes         String?

  // Attribution
  qrCodeId      Int?       @map("qr_code_id")
  campaignId    Int?       @map("campaign_id")
  userId        Int        @map("user_id")

  customFields  Json?      @map("custom_fields") // extra data fields form collects

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCode        QRCode?    @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  campaign      Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@map("leads")
}

model Conversion {
  id         Int                 @id @default(autoincrement())
  qrCodeId   Int                 @map("qr_code_id")
  campaignId Int?                @map("campaign_id")

  eventType  ConversionEventType @map("event_type")
  eventName  String?             @map("event_name") // for custom actions
  value      Decimal?            @db.Decimal(10, 2)
  currency   String?             @default("INR")

  occurredAt DateTime            @default(now()) @map("occurred_at")

  qrCode     QRCode              @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  campaign   Campaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([qrCodeId])
  @@index([occurredAt])
  @@map("conversions")
}

model LandingPage {
  id           Int        @id @default(autoincrement())
  slug         String     @unique                                  // URL identifier: /p/{slug}
  title        String
  theme        String     @default("dark")                         // e.g. dark, light, sunset, ocean, glassmorphism
  
  // Custom profile components
  profileName  String?    @map("profile_name")
  bio          String?
  avatarUrl    String?    @map("avatar_url")
  socialLinks  Json?      @map("social_links")                     // { instagram?, facebook?, linkedin?, twitter?, whatsapp?, phone?, email? }
  buttons      Json?      @map("buttons")                          // Array of { id, label, url, order }
  
  userId       Int        @map("user_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCodes      QRCode[]

  @@index([userId])
  @@index([slug])
  @@map("landing_pages")
}

model Restaurant {
  id           Int             @id @default(autoincrement())
  userId       Int             @unique @map("user_id")
  name         String
  description  String?         @db.Text
  logoUrl      String?         @map("logo_url")
  coverImage   String?         @map("cover_image")
  currency     String          @default("INR")
  taxRate      Decimal         @default(0.00) @db.Decimal(5, 2) @map("tax_rate")
  taxName      String          @default("GST") @map("tax_name")
  
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  menus        Menu[]
  categories   MenuCategory[]
  tables       RestaurantTable[]
  qrCodes      QRCode[]

  @@map("restaurants")
}

model Menu {
  id           Int             @id @default(autoincrement())
  restaurantId Int             @map("restaurant_id")
  name         String
  description  String?         @db.Text
  theme        String          @default("modern") // modern, minimal, premium, cafe
  isDefault    Boolean         @default(false) @map("is_default")
  
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categories   MenuCategory[]
  tables       RestaurantTable[]

  @@map("menus")
}

model MenuCategory {
  id           Int          @id @default(autoincrement())
  restaurantId Int          @map("restaurant_id")
  menuId       Int          @map("menu_id")
  name         String
  order        Int          @default(0)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menu         Menu         @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items        MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id           Int          @id @default(autoincrement())
  categoryId   Int          @map("category_id")
  name         String
  description  String?      @db.Text
  price        Decimal      @db.Decimal(10, 2)
  variants     Json?        // [{ "label": "Half", "price": 120 }, { "label": "Full", "price": 200 }]
  image        String?
  isAvailable  Boolean      @default(true) @map("is_available")
  isVeg        Boolean      @default(true) @map("is_veg")
  isNonVeg     Boolean      @default(false) @map("is_non_veg")
  isVegan      Boolean      @default(false) @map("is_vegan")
  isPopular    Boolean      @default(false) @map("is_popular")
  order        Int          @default(0)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  category     MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("menu_items")
}

model RestaurantTable {
  id           Int        @id @default(autoincrement())
  restaurantId Int        @map("restaurant_id")
  menuId       Int?       @map("menu_id")
  tableNumber  String     @map("table_number")
  capacity     Int?        @default(4)
  qrCodeId     Int?       @unique @map("qr_code_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menu         Menu?      @relation(fields: [menuId], references: [id], onDelete: SetNull)
  qrCode       QRCode?    @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)

  @@map("restaurant_tables")
}
